{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "scripts/hooks/ospec-hooks session-start",
        "powershell": "scripts/hooks/ospec-hooks session-start"
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "scripts/hooks/ospec-hooks pre-tool-use",
        "powershell": "scripts/hooks/ospec-hooks pre-tool-use",
        "timeoutSec": 5
      }
    ]
  }
}