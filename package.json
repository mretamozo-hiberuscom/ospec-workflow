{
  "name": "ospec-workflow",
  "version": "2.4.6",
  "private": true,
  "description": "Spec-Driven Development workflow with OpenSpec, strict TDD, phase agents, skills, hooks, and verification contracts.",
  "license": "MIT",
  "author": {
    "name": "Manuel Michael Retamozo García"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mretamozo-hiberuscom/ospec-workflow.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node scripts/check.js",
    "build:claude": "node scripts/configure/claude-marketplace.js",
    "setup:claude": "node scripts/configure/install-claude.js",
    "reload:claude": "node scripts/configure/install-claude.js --build-only",
    "build:copilot": "node scripts/configure/cli.js --target github-copilot --out dist/github-copilot",
    "setup:copilot": "node scripts/configure/install-global-copilot.js",
    "reload:copilot": "node scripts/configure/install-global-copilot.js",
    "build:opencode": "node scripts/configure/cli.js --target opencode --out dist/opencode",
    "setup:opencode": "node scripts/configure/install-global-opencode.js",
    "reload:opencode": "node scripts/configure/install-global-opencode.js",
    "build:vscode": "node scripts/configure/cli.js --target vscode --out dist/vscode",
    "setup:vscode": "node scripts/configure/install-vscode.js",
    "reload:vscode": "npm run build:vscode",
    "install:opencode": "node scripts/configure/install-target.js opencode",
    "install:global:opencode": "node scripts/configure/install-global-opencode.js",
    "install:global:copilot": "node scripts/configure/install-global-copilot.js",
    "install:copilot": "node scripts/configure/install-target.js github-copilot"
  }
}
