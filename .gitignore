# Runtime session renders — derivados efímeros de openspec/changes/**/state.yaml,
# regenerados por los hooks. La verdad versionada es state.yaml (en openspec/),
# no estos renders. Mantener local para evitar trazabilidad stale en git.
.ospec/

# Atlas de federación — cache derivado y regenerable. La verdad son los marcadores
# openspec/federation.member.yaml de cada repo miembro; openspec/workspace.yaml se
# reconstruye desde ellos y NUNCA se versiona como artefacto canónico.
openspec/workspace.yaml

# Build outputs and coverage
dist/
coverage/

# Node
node_modules/
npm-debug.log*

# Python
__pycache__/
*.pyc

# Editor / OS noise
.DS_Store
Thumbs.db
.idea/
*.swp

.atl/
.antigravitycli/

# ospec-hooks compiled binaries (built by CI, never committed)
release/dist/ospec-hooks
release/dist/ospec-hooks.exe
release/dist/ospec-hooks-*
scripts/hooks/ospec-hooks
scripts/hooks/ospec-hooks.exe
/ospec-hooks
/ospec-hooks.exe

# federation baseline working state — change-scoped, not a canonical artifact
openspec/changes/*/federation-baseline-status.yaml
openspec/changes/*/federation-baseline-status.yaml.tmp
openspec/changes/*/federation-baseline-status.yaml.bak
